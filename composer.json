{
    "name": "martincarmona/personal-site",
    "description": "Web de marca personal de Martín Carmona",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "league/commonmark": "^2.4"
    },
    "require-dev": {},
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Composer\\Config::disableProcessTimeout"
        ]
