APP_ENV=local
APP_URL=http://localhost/martincarmona1/public

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=martincarmona
DB_USERNAME=root
DB_PASSWORD=

# ─── Módulo Planner (Fase 7) ─────────────────────────────
# API de Anthropic (Claude Sonnet 4.6) para generación de horarios.
ANTHROPIC_API_KEY=
# Modo dry-run del módulo de IA: si es 1, no se llama a Anthropic y se
# devuelve un horario sintético. Útil para desarrollar sin gastar tokens.
PLANNER_AI_DRY_RUN=0
# Bot de Telegram que envía notificaciones y recibe respuestas.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Token compartido entre el cron de Hostinger y /planner/tick.
# Generar con: php -r "echo bin2hex(random_bytes(32));"
PLANNER_TICK_TOKEN=
# Credenciales de acceso al panel del Planner (single-user, solo Martín).
# El hash se genera con: php bin/planner-hash-password.php
PLANNER_USERNAME=
PLANNER_PASSWORD_HASH=
